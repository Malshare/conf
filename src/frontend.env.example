# === Database ===
MALSHARE_DB_HOST=your-db-host
MALSHARE_DB_USER=your-db-user
MALSHARE_DB_PASS=your-db-password
MALSHARE_DB_DATABASE=malshare_db
MALSHARE_DB_PORT=3306
MALSHARE_DB_CERT=

# === reCAPTCHA ===
MALSHARE_RECAPTCHA_SECRET=your-recaptcha-secret

# === Mailgun (registration emails) ===
MALSHARE_MAILGUN_SMTP=your-mailgun-smtp-host
MALSHARE_MAILGUN_PORT=587
MALSHARE_MAILGUN_FROM=noreply@your-domain.com
MALSHARE_MAILGUN_USERNAME=your-mailgun-username
MALSHARE_MAILGUN_PASSWORD=your-mailgun-password

# === VirusTotal Context Widget ===
VT_CONTEXT_KEY=your-vt-api-key
VT_CONTEXT_URL=https://www.virustotal.com/api/v3/widget/url?mode=standalone&query=

# === Wasabi / S3 Storage ===
WASABI_ENDPOINT=https://s3.wasabisys.com
WASABI_REGION=your-wasabi-region
WASABI_KEY=your-wasabi-access-key
WASABI_SECRET=your-wasabi-secret-key
WASABI_BUCKET=malshare-samples

# === Cloudflare Tunnel ===
TUNNEL_TOKEN=your-cloudflare-tunnel-token
